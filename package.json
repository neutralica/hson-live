{
  "name": "hson-live",
  "version": "3.0.0",
  "description": "HSON-live 2026",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "author": "terminal_gothic",
  "license": "Parity-7.0.0",
  "keywords": [
    "html",
    "json",
    "glue format"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./hson": {
      "types": "./dist/hson.d.ts",
      "import": "./dist/hson.js"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics/index.d.ts",
      "import": "./dist/diagnostics/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./diagnostics/test-exports": "./dist/_tests/test-exports.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "check:source": "tsc -p tsconfig.json --noEmit",
    "check:tests": "tsc -p tests/tsconfig.json --noEmit",
    "check": "npm run check:source && npm run check:tests",
    "test:hson-tokenizer": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/hson-tokenizer.acceptance.mts",
    "test:hson-serializer": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/hson-serializer.acceptance.mts",
    "test:public-boundaries": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/public-boundaries.acceptance.mts",
    "test:livemap-document": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/livemap-document.acceptance.mts",
    "test:livemap-document-install": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/livemap-document-install.acceptance.mts",
    "test:livemap-document-mutation": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/livemap-document-mutation.acceptance.mts",
    "test:livemap-document-replay": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/livemap-document-replay.acceptance.mts",
    "test:livehost-recovery": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/runtime-probes/livehost-recovery.acceptance.mjs",
    "test:livehost-client-recovery": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/runtime-probes/livehost-client-recovery.acceptance.mjs",
    "test:livehost-document-recovery": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/runtime-probes/livehost-document-recovery.acceptance.mjs",
    "test:livehost-document-actions": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/runtime-probes/livehost-document-actions.acceptance.mjs",
    "test:livehost-protocol-document": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/runtime-probes/livehost-protocol-document.acceptance.mjs",
    "test:livehost-session": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/runtime-probes/livehost-session.acceptance.mjs",
    "test:livehost-action-dedupe": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/runtime-probes/livehost-action-dedupe.acceptance.mjs",
    "test:livehost-trace": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/runtime-probes/livehost-trace.acceptance.mjs",
    "test:livehost-authorization": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm tests/runtime-probes/livehost-authorization.acceptance.mjs"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.20.1",
    "@types/ws": "^8.18.1",
    "chokidar-cli": "^3.0.0",
    "npm-run-all": "^4.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "ws": "^8.21.1"
  },
  "dependencies": {
    "dompurify": "^3.3.0"
  }
}
